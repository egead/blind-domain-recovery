                        },
                        {
                            "filters": 8,
                            "kernel_size": [
                                3,
                                3
                            ],
                            "strides": [
                                1,
                                1
                            ],
                            "pooling": true
                        }
                    ]
                }
            ]
        },
        "model_loss_coeffs": {
            "uniformity_maximization_reg_coeff": 1.0,
